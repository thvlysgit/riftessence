# Example environment variables (do NOT commit real secrets)
# Copy to .env and fill values locally

# === REQUIRED ===
RIOT_API_KEY=your-riot-api-key-here
DATABASE_URL=postgresql://postgres:password@localhost:5432/riftessence

# === OPTIONAL (with defaults) ===
NODE_ENV=development
PORT=3333
NEXT_PUBLIC_API_URL=http://localhost:3333
ALLOW_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# === AUTHENTICATION ===
# JWT Secret for token signing (optional - will be auto-generated if not set)
JWT_SECRET=your-jwt-secret-change-in-production

# === CAPTCHA ===
# Cloudflare Turnstile secret (optional - only needed if using CAPTCHA)
TURNSTILE_SECRET_KEY=

# === EMAIL RECOVERY (optional; required for forgot-password emails) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=RiftEssence
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# === DISCORD INTEGRATION ===
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3333/api/auth/discord/callback
DISCORD_BOT_API_KEY=

# === RIOT SIGN-ON (RSO) ===
# Get these from https://developer.riotgames.com/ after RSO approval
RIOT_RSO_CLIENT_ID=
RIOT_RSO_CLIENT_SECRET=
RIOT_RSO_REDIRECT_URI=http://localhost:3333/api/auth/riot/callback
RIOT_RSO_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# === CACHING (optional) ===
REDIS_URL=redis://localhost:6379

# === DEVELOPMENT ===
# Use fake Riot API responses (0 = real API, 1 = fake)
USE_FAKE_RIOT=0
USE_FAKE_DB=0

# aa